project_name = "lago-alpha"
environment  = "prod"
aws_region   = "us-east-1"

# Optional. Set to a 12-digit account id to avoid aws_caller_identity lookup in some CI plan flows.
aws_account_id = ""

azs = ["us-east-1a", "us-east-1b", "us-east-1c"]

vpc_cidr        = "10.50.0.0/16"
private_subnets = ["10.50.0.0/20", "10.50.16.0/20", "10.50.32.0/20"]
public_subnets  = ["10.50.128.0/20", "10.50.144.0/20", "10.50.160.0/20"]

eks_node_instance_types = ["m6i.xlarge"]
eks_node_desired_size   = 3
eks_node_min_size       = 3
eks_node_max_size       = 12

# Prefer trusting an AWS Identity Center/SSO admin role here. Keep a direct IAM user only if you still need CLI continuity during bootstrap.
eks_cluster_admin_principal_arns = []

eks_admin_role_trusted_principal_arns = [
  "arn:aws:iam::123456789012:role/aws-reserved/sso.amazonaws.com/REGION/AWSReservedSSO_AdministratorAccess_example",
]

db_name                  = "lago_alpha"
db_username              = "lago_alpha_admin"
db_password              = "replace-with-prod-secret"
db_instance_class        = "db.r6g.xlarge"
db_allocated_storage     = 200
db_max_allocated_storage = 2000
db_multi_az              = true

audit_exports_bucket_force_destroy = false

external_secrets_namespace       = "external-secrets"
external_secrets_service_account = "external-secrets"
runtime_secret_name              = "lago-alpha/prod/runtime"
create_runtime_secret            = true
runtime_secret_recovery_window_in_days = 30

tags = {
  Owner       = "billing-platform"
  Environment = "prod"
  Tier        = "critical"
}
